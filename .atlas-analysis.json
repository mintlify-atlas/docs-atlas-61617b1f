  "keyFeatures": [
    "Multi-format content publishing (podcasts, blogs, photos, videos, documents, URLs)",
    "Web, RSS, and JSON feed generation",
    "Admin dashboard with visual editor",
    "Custom HTML/CSS theming with Mustache templating",
    "Media file hosting with Cloudflare R2",
    "Cloudflare D1 database for metadata",
    "Public JSON API with OpenAPI spec",
    "Admin API for programmatic content management",
    "Cloudflare Zero Trust authentication",
    "Serverless architecture on Cloudflare Pages"
